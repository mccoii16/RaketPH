{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the RaketPH platform, either an employee or an employer.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["employee", "employer"], "description": "The user's role in the marketplace." },
        "isVouched": { "type": "boolean", "description": "Whether the user has a verified badge." },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "A list of the user's skills." },
        "intro": { "type": "string", "description": "A short bio or introduction." },
        "certificates": { "type": "array", "items": { "type": "string" }, "description": "URLs to pinned certificates in Firebase Storage." },
        "companyName": { "type": "string", "description": "Employer only: Company Name" },
        "industry": { "type": "string", "description": "Employer only: Industry" },
        "primarySkill": { "type": "string", "description": "Employee only: Primary Skill" },
        "experienceLevel": { "type": "string", "description": "Employee only: Experience Level" },
        "experience": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "company": { "type": "string" },
              "position": { "type": "string" },
              "duration": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "school": { "type": "string" },
              "degree": { "type": "string" },
              "year": { "type": "string" }
            }
          }
        },
        "savedJobs": { "type": "array", "items": { "type": "string" }, "description": "A list of job IDs the user has bookmarked." }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Job": {
      "title": "Job",
      "description": "A job posting created by an employer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employerId": { "type": "string" },
        "employerName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "salaryRange": { "type": "string" },
        "cultureTags": { "type": "array", "items": { "type": "string" } },
        "requiredSkills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employerId", "title", "description", "cultureTags", "requiredSkills"]
    },
    "Application": {
      "title": "Application",
      "description": "A job application submitted by an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "employeePhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "seen", "shortlisted", "rejected"] },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "employeeId", "status"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between an employer and an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "The UIDs of the participants." },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "employerId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employerName": { "type": "string" },
        "employeeName": { "type": "string" },
        "employerPhoto": { "type": "string" },
        "employeePhoto": { "type": "string" }
      },
      "required": ["participants", "employerId", "employeeId"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job posting data."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job application data."
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Conversation data."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Message data."
    }
  }
}
